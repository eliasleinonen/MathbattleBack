# ========================================
# Derivative Duel - Backend Configuration
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# ========================================
# DATABASE CONFIGURATION
# ========================================

# MongoDB Connection String
# Local development:
MONGODB_URL=mongodb://localhost:27017

# Production (MongoDB Atlas):
# MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Example: mongodb+srv://admin:mypassword@cluster0.abc123.mongodb.net/?retryWrites=true&w=majority

# Database Name
DATABASE_NAME=derivative_duel

# ========================================
# SECURITY & AUTHENTICATION
# ========================================

# Secret Key for JWT Token Signing
# IMPORTANT: Generate a secure random key using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-to-random-string

# JWT Token Expiration (in minutes)
# Default: 10080 minutes = 7 days
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ========================================
# GOOGLE OAUTH 2.0 CONFIGURATION (OPTIONAL)
# ========================================
# OAuth is disabled in demo mode - all players play as guests
# To enable OAuth, uncomment the imports in main.py and set these:

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret
# Get from: https://console.cloud.google.com/apis/credentials
# OAUTH=your-google-oauth-secret

# ========================================
# CORS (Cross-Origin Resource Sharing)
# ========================================

# Comma-separated list of allowed origins (no spaces)
# Development:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Production (add your deployed frontend URL):
# CORS_ORIGINS=https://mathbattle.xyz,https://www.mathbattle.xyz,http://localhost:3000
